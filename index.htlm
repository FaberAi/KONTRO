<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>KONTRO</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: #0B0B0B;
      color: white;
    }

    .container {
      padding: 40px;
      max-width: 800px;
      margin: auto;
    }

    h1 {
      margin-bottom: 10px;
    }

    button {
      padding: 10px 20px;
      background: #00C897;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      margin-top: 10px;
    }

    #movimenti {
      margin-top: 30px;
    }

    .mov {
      padding: 10px;
      border-bottom: 1px solid #333;
    }
  </style>
</head>

<body>

  <div class="container">
    <h1>KONTRO</h1>
    <p>Gestione semplice dei tuoi movimenti</p>

    <button onclick="aggiungiMovimento()">+ Movimento</button>

    <div id="movimenti"></div>
  </div>

  <!-- SUPABASE -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js"></script>

  <!-- APP -->
  <script src="app.js"></script>

</body>
</html>
